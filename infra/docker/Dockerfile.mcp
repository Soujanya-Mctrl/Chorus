FROM node:20-alpine AS base

FROM base AS builder
WORKDIR /app
RUN apk add --no-cache libc6-compat python3 make g++
RUN npm install -g turbo
COPY . .
RUN turbo prune @chorus/mcp --docker

FROM base AS installer
RUN apk add --no-cache libc6-compat python3 make g++
WORKDIR /app
COPY --from=builder /app/out/json/ .
COPY --from=builder /app/out/package-lock.json ./package-lock.json
RUN npm install
COPY --from=builder /app/out/full/ .
COPY turbo.json turbo.json
COPY tsconfig.base.json tsconfig.base.json
RUN npx turbo run build --filter=@chorus/shared-types
# install dependencies
RUN npm install

# build shared-types manually
RUN cd packages/shared-types && npm run build

# build mcp manually
RUN cd apps/mcp && npm run build

FROM base AS runner
WORKDIR /app
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 mcpjs
USER mcpjs

COPY --from=installer --chown=mcpjs:nodejs /app .

EXPOSE 3002
CMD ["node", "apps/mcp/dist/server.js"]
